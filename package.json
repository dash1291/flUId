{
  "name": "@fluid/ui",
  "version": "0.1.0",
  "private": true,
  "description": "flUId — A reusable chat UI framework for LLM-powered applications with interactive widgets",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./hooks": {
      "import": "./src/hooks/useAgent.ts",
      "types": "./src/hooks/useAgent.ts"
    },
    "./server": {
      "import": "./src/server/createAgentRoute.ts",
      "types": "./src/server/createAgentRoute.ts"
    },
    "./types": {
      "import": "./src/types.ts",
      "types": "./src/types.ts"
    },
    "./ui": {
      "import": "./src/ui/index.ts",
      "types": "./src/ui/index.ts"
    }
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "next": "^16",
    "react-markdown": "^10"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
